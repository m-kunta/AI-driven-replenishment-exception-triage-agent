# =============================================================================
# Single source of truth for both the FastAPI backend AND the Next.js frontend.
# Copy this file to .env and fill in real values.
#
# Start the full stack (backend + frontend) with:
#   bash scripts/dev.sh
# =============================================================================

# ── Web UI — API credentials (backend enforces, frontend reads via next.config.ts) ──
API_USERNAME=replace_with_api_username
API_PASSWORD=replace_with_strong_password

# Port the FastAPI backend listens on. Change if 8000 is already in use.
# API_URL must match so the Next.js proxy knows where to forward requests.
BACKEND_PORT=8000
API_URL=http://localhost:8000

# ── Per-user role mappings (optional) ──────────────────────────────────────────
# Comma-separated username:role pairs. Supported roles: analyst, planner.
# Users listed here authenticate with the same API_PASSWORD as API_USERNAME.
# If a username has no entry, API_USER_ROLE is used as the fallback.
# Example: API_USER_ROLES=alice:planner,bob:analyst
API_USER_ROLES=

# Default role for API_USERNAME and any user not listed in API_USER_ROLES.
# Must be either "analyst" or "planner".
API_USER_ROLE=analyst

# ── AI Provider — optional env overrides for local runs ────────────────────────
# AGENT_PROVIDER overrides config/config.yaml provider without editing YAML.
# Supported: claude | openai | gemini | ollama
# AGENT_MODEL is optional; if omitted, a provider-appropriate default is used.
AGENT_PROVIDER=
AGENT_MODEL=

# Supply the key for the provider you are using below.

# Required when provider=claude (default)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required when provider=openai
OPENAI_API_KEY=your_openai_api_key_here

# Required when provider=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Optional when provider=ollama (default base URL: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Required for API adapter mode (optional if using CSV or SQL)
EXCEPTION_API_ENDPOINT=https://your-planning-system.com/api/exceptions
EXCEPTION_API_KEY=your_api_key

# Required for SQL adapter mode (optional if using CSV or API)
DB_CONNECTION_STRING=postgresql://user:password@host:5432/dbname

# Required for email alerts (optional if alerts disabled)
SMTP_HOST=smtp.yourdomain.com
ALERT_FROM_EMAIL=triage-agent@yourdomain.com
PLANNER_EMAIL=planner@yourdomain.com
CATEGORY_MANAGER_EMAIL=category.manager@yourdomain.com

# Optional: Slack/Teams alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Optional: Phantom Inventory Agent integration
PHANTOM_WEBHOOK_URL=http://localhost:8001/api/verify
